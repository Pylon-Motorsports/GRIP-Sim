{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-vs2019",
      "displayName": "Windows (VS 2019)",
      "description": "Build with MSVC 2019. SDL2 fetched automatically if not in PATH.",
      "generator": "Visual Studio 16 2019",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-vs2022",
      "displayName": "Windows (VS 2022)",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-vs2019-release",
      "inherits": "windows-vs2019",
      "displayName": "Windows Release (VS 2019)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-default",
      "displayName": "Linux (GCC/Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2019",
      "configurePreset": "windows-vs2019"
    },
    {
      "name": "windows-vs2022",
      "configurePreset": "windows-vs2022"
    },
    {
      "name": "windows-vs2019-release",
      "configurePreset": "windows-vs2019-release"
    },
    {
      "name": "linux-default",
      "configurePreset": "linux-default"
    }
  ]
}
